{
  "action": "write_essay",
  "apps": {
    "allow": ["word.exe"],
    "deny": []
  },
  "web": {
    "allow": ["researchgate.net", "scholar.google.com"],
    "deny": ["reddit.com", "discord.com"],
    "wildcard": true
  },
  "emotion": {
    "allow": ["neutral", "happy"],
    "deny": ["angry", "fear"]
  },
  "vision": {
    "require_presence": true,
    "away_grace_sec": 10
  },
  "session_time_limit": 5400,
  "enforcement_level": "lenient",
  "camera_displayed": true
}

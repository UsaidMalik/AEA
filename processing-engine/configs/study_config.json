{
  "action": "study",
  "apps": {
    "allow": ["word.exe", "onenote.exe"],
    "deny": ["discord.exe", "tiktok.exe"]
  },
  "web": {
    "allow": ["khanacademy.org", "wikipedia.org"],
    "deny": ["youtube.com", "facebook.com", "twitter.com", "instagram.com", "tiktok.com", "linkedin.com"],
    "wildcard": true
  },
  "emotion": {
    "allow": ["happy", "calm"],
    "deny": ["neutral", "angry", "disgust", "fear", "sad", "missing"]
  },
  "vision": {
    "require_presence": true,
    "away_grace_sec": 5
  },
  "session_time_limit": 3600,
  "enforcement_level": "strict",
  "camera_displayed": true
}
